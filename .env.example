# .env.example - Copy this to .env and fill in actual values

# SQL Server (OrderService)
SQLSERVER_PASSWORD=YourStrong!Password
SQLSERVER_PORT=1433

# MongoDB (ProductCatalogService)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpassword
MONGO_PORT=27017

# PostgreSQL (InventoryService)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=InventoryDB
POSTGRES_PORT=5432

# API Ports
ORDER_SERVICE_PORT=5001
PRODUCT_CATALOG_SERVICE_PORT=5002
INVENTORY_SERVICE_PORT=5003
NOTIFICATION_SERVICE_PORT=5004
API_GATEWAY_PORT=8080

# Environment
ASPNETCORE_ENVIRONMENT=Docker
